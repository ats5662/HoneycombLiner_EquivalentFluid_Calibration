environment
  tabular_data
    tabular_data_file = 'results2.dat'
	
method
  nl2sol
  max_function_evaluations = 500
  max_iterations = 500
  speculative
      
variables
  continuous_design = 8
    descriptors     'x1'    'x2'    'x3'    'x4'     'x5'     'x6'     'x7'    'x8'
    initial_point   4.7809893472e-01 -1.5242483425e+00 2.0148210369e+00 -1.2879639593e+01 1.2793401464e+03 -7.3782045582e+03 9.5036321534e+02 -6.9212465053e+03    
            	 
interface
  asynchronous evaluation_concurrency = 8
  fork
    analysis_driver = 'driver2.sh'
      work_directory
        named 'workDirectory2/iteration'
      copy_files
        'driver2.sh'
	    'calcSimResults2.py'
	    'calcAbsorptionCoefficient.py'
	    '/home/ats5662/HoneycombLiner_EquivalentFluid_Calibration/materialInputDeck.template'
	    'harmonicAcousticSimInputDeck2.template'
	    '/home/ats5662/HoneycombLiner_EquivalentFluid_Calibration/Hex_PLA_1_AllData.csv'
	    '/home/ats5662/HoneycombLiner_EquivalentFluid_Calibration/Hex_PLA_2_AllData.csv'
	    '/home/ats5662/HoneycombLiner_EquivalentFluid_Calibration/Hex_PLA_3_AllData.csv'
    	'/home/ats5662/HoneycombLiner_EquivalentFluid_Calibration/Hex_TPU_1_AllData.csv'
	    '/home/ats5662/HoneycombLiner_EquivalentFluid_Calibration/Hex_TPU_2_AllData.csv'
	    '/home/ats5662/HoneycombLiner_EquivalentFluid_Calibration/Hex_TPU_3_AllData.csv'
	    'HexLinerMeshMeterTet4.cdb'
	    directory_tag
	    directory_save
	    file_save
	  
responses
  calibration_terms = 30
  numerical_gradients
  no_hessians
