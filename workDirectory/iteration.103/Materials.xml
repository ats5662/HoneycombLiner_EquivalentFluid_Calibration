<?xml version='1.0' encoding='utf-8'?>
<cfsMaterialDataBase
	xmlns='http://www.cfs++.org/material'
	xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'
	xsi:schemaLocation='http://www.cfs++.org/material 
    https://opencfs.gitlab.io/cfs/xml/CFS-Material/CFS_Material.xsd'>

	<material name='Air'>
		<acoustic>
			<density>
				<linear>
					<real>1.2</real>
				</linear>
			</density>
			<densityComplex>
				<linear>
					<real>1.2</real>
					<imag>0.0</imag>
				</linear>
			</densityComplex>
			<compressionModulus>
				<linear>
					<real>138720.0</real>
				</linear>
			</compressionModulus>
			<compressionModulusComplex>
				<linear>
					<real>138720.0</real>
					<imag>0.0</imag>
				</linear>
			</compressionModulusComplex>
		</acoustic>
	</material>
		<material name='MPP'>
		<acoustic>
			<density>
				<linear>
					<real>1.2</real>
				</linear>
			</density>
			<densityComplex>
				<linear>
					<real>0.583473014*log(f)+-2.332874158</real>
					<imag>-0.5341745112*log(f)+5.514376105</imag> 
				</linear>
			</densityComplex>
			<compressionModulus>
				<linear>
					<real>138720.0</real>
				</linear>
			</compressionModulus>
			<compressionModulusComplex>
				<linear>
					<real>1253.637065*log(f)+-7483.647522</real>
