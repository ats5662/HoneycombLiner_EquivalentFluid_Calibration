		</acoustic>
	</material>
		<material name='MPP'>
		<acoustic>
			<density>
				<linear>
					<real>1.2</real>
				</linear>
			</density>
			<densityComplex>
				<linear>
					<real>0.2017187854*log(f)+0.4563601151</real>
					<imag>-0.6657304843*log(f)+6.171532746</imag> 
				</linear>
			</densityComplex>
			<compressionModulus>
				<linear>
					<real>138720.0</real>
				</linear>
			</compressionModulus>
			<compressionModulusComplex>
				<linear>
					<real>754.8623933*log(f)+-2610.48276</real>
					<imag>157.547997*log(f)+-1620.11082</imag>
