<?xml version='1.0' encoding='utf-8'?>
<cfsMaterialDataBase
	xmlns='http://www.cfs++.org/material'
	xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'
	xsi:schemaLocation='http://www.cfs++.org/material 
    https://opencfs.gitlab.io/cfs/xml/CFS-Material/CFS_Material.xsd'>

	<material name='Air'>
		<acoustic>
			<density>
				<linear>
					<real>1.2</real>
				</linear>
			</density>
			<densityComplex>
				<linear>
					<real>1.2</real>
					<imag>0.0</imag>
				</linear>
			</densityComplex>
			<compressionModulus>
				<linear>
					<real>138720.0</real>
				</linear>
			</compressionModulus>
			<compressionModulusComplex>
				<linear>
					<real>138720.0</real>
					<imag>0.0</imag>
				</linear>
			</compressionModulusComplex>
		</acoustic>
	</material>
		<material name='MPP'>
		<acoustic>
			<density>
				<linear>
					<real>1.2</real>
				</linear>
			</density>
			<densityComplex>
				<linear>
					<real>0.5282160216*log(f)+-1.916414351</real>
					<imag>-0.1206006044*log(f)+2.47088842</imag> 
				</linear>
			</densityComplex>
			<compressionModulus>
				<linear>
					<real>138720.0</real>
				</linear>
			</compressionModulus>
			<compressionModulusComplex>
				<linear>
					<real>1155.558393*log(f)+-6302.163029</real>
					<imag>166.871105*log(f)+-1123.17237</imag>
				</linear>
			</compressionModulusComplex>
		</acoustic>
	</material>
</cfsMaterialDataBase>
