<?xml version='1.0' encoding='utf-8'?>
<cfsMaterialDataBase
	xmlns='http://www.cfs++.org/material'
	xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'
	xsi:schemaLocation='http://www.cfs++.org/material 
    https://opencfs.gitlab.io/cfs/xml/CFS-Material/CFS_Material.xsd'>

	<material name='Air'>
		<acoustic>
			<density>
				<linear>
					<real>1.2</real>
				</linear>
			</density>
			<densityComplex>
				<linear>
					<real>1.2</real>
					<imag>0.0</imag>
				</linear>
			</densityComplex>
			<compressionModulus>
				<linear>
					<real>138720.0</real>
				</linear>
			</compressionModulus>
			<compressionModulusComplex>
				<linear>
					<real>138720.0</real>
					<imag>0.0</imag>
				</linear>
			</compressionModulusComplex>
		</acoustic>
	</material>
		<material name='MPP'>
		<acoustic>
			<density>
				<linear>
					<real>1.2</real>
				</linear>
			</density>
			<densityComplex>
				<linear>
					<real>0.3536342248*log(f)+-0.6572729062</real>
					<imag>-0.3225862936*log(f)+3.82785688</imag> 
				</linear>
			</densityComplex>
			<compressionModulus>
				<linear>
					<real>138720.0</real>
				</linear>
			</compressionModulus>
			<compressionModulusComplex>
				<linear>
					<real>1426.561125*log(f)+-7909.971009</real>
					<imag>104.5698521*log(f)+-708.9373492</imag>
				</linear>
			</compressionModulusComplex>
		</acoustic>
	</material>
</cfsMaterialDataBase>
