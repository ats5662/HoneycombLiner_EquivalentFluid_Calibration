<?xml version='1.0' encoding='utf-8'?>
<cfsMaterialDataBase
	xmlns='http://www.cfs++.org/material'
	xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'
	xsi:schemaLocation='http://www.cfs++.org/material 
    https://opencfs.gitlab.io/cfs/xml/CFS-Material/CFS_Material.xsd'>

	<material name='Air'>
		<acoustic>
			<density>
				<linear>
					<real>1.2</real>
				</linear>
			</density>
			<densityComplex>
				<linear>
					<real>1.2</real>
					<imag>0.0</imag>
				</linear>
			</densityComplex>
			<compressionModulus>
				<linear>
					<real>138720.0</real>
				</linear>
			</compressionModulus>
			<compressionModulusComplex>
				<linear>
					<real>138720.0</real>
					<imag>0.0</imag>
				</linear>
			</compressionModulusComplex>
		</acoustic>
	</material>
		<material name='MPP'>
		<acoustic>
			<density>
				<linear>
					<real>1.2</real>
				</linear>
			</density>
			<densityComplex>
				<linear>
					<real>0.4780601192*log(f)+-1.523920356</real>
					<imag>2.016973478*log(f)+-12.88061717</imag> 
				</linear>
			</densityComplex>
			<compressionModulus>
				<linear>
					<real>138720.0</real>
				</linear>
			</compressionModulus>
			<compressionModulusComplex>
				<linear>
					<real>1279.330135*log(f)+-7378.176999</real>
					<imag>950.3709911*log(f)+-6921.297743</imag>
				</linear>
			</compressionModulusComplex>
		</acoustic>
	</material>
</cfsMaterialDataBase>
